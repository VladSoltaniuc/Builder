{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "RateLimiting": {
    "Enabled": true,
    "PermitLimit": 100,
    "WindowSeconds": 60
  },
  "IndexMaintenance": {
    "Enabled": true,
    "Frequency": "Weekly",
    "Day": 0,
    "Hour": 3,
    "Minute": 0,
    "BloatThresholdPercent": 30,
    "MinIndexSizeMb": 1
  }
}
