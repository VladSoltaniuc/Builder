{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "App": {
    "FrontendUrl": "http://localhost:5173"
  },
  "Jwt": {
    "Issuer": "ProductApi",
    "Audience": "ProductApiClient",
    "Key": "dev-only-signing-key-change-me-in-production-0123456789",
    "ExpiryMinutes": 60
  },
  "Authentication": {
    "Google": {
      "ClientId": ""
    }
  },
  "RateLimiting": {
    "Enabled": true,
    "PermitLimit": 100,
    "WindowSeconds": 60
  },
  "Smtp": {
    "Host": "",
    "Port": 587,
    "UseStartTls": true,
    "Username": "",
    "Password": "",
    "FromAddress": "reports@productapi.local",
    "FromName": "ProductApi Reports"
  },
  "Sms": {
    "AccountSid": "",
    "AuthToken": "",
    "FromNumber": ""
  },
  "WeeklyReport": {
    "Enabled": false,
    "Day": 1,
    "Hour": 8,
    "Minute": 0
  },
  "IndexMaintenance": {
    "Enabled": true,
    "Frequency": "Weekly",
    "Day": 0,
    "Hour": 3,
    "Minute": 0,
    "BloatThresholdPercent": 30,
    "MinIndexSizeMb": 1
  }
}
