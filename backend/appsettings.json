{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Jwt": {
    "Issuer": "ProductApi",
    "Audience": "ProductApiClient",
    "Key": "dev-only-signing-key-change-me-in-production-0123456789",
    "ExpiryMinutes": 60
  },
  "Authentication": {
    "Google": {
      "ClientId": ""
    }
  },
  "RateLimiting": {
    "Enabled": true,
    "PermitLimit": 100,
    "WindowSeconds": 60
  },
  "IndexMaintenance": {
    "Enabled": true,
    "Frequency": "Weekly",
    "Day": 0,
    "Hour": 3,
    "Minute": 0,
    "BloatThresholdPercent": 30,
    "MinIndexSizeMb": 1
  }
}
